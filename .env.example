# Copy this file to .env and fill in real values for your deployment.
# Locally, if you don't create a .env file, the app falls back to safe local defaults (SQLite, DEBUG=True).

SECRET_KEY=replace-this-with-a-long-random-secret-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://your-app.onrender.com

# Provided automatically by Render/Railway when you attach a PostgreSQL database.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@host:5432/gorental
